# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = OMARCHY
font-size = 14

adjust-cell-height=-5%

# Window
window-padding-x = 0
window-padding-y = 0
confirm-close-surface=false
resize-overlay = never


# Keyboard bindings
keybind = ctrl+backspace=text:\x17
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = shift+enter=text:\x1b\r

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll

# Keep notifications without asking the compositor to focus the window.
bell-features = system,title,no-attention
